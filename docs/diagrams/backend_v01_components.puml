@startuml backend_v01_components
title Workstream v0.1 Backend Component View

left to right direction

skinparam backgroundColor #FFFFFF
skinparam shadowing false
skinparam roundcorner 8
skinparam defaultFontName Arial
skinparam defaultFontSize 15
skinparam ArrowColor #495057
skinparam ArrowThickness 1.1
skinparam packageStyle rectangle
skinparam rectangle {
  BorderColor #1C7ED6
  BackgroundColor #E7F5FF
  FontColor #0B2942
}
skinparam database {
  BorderColor #0CA678
  BackgroundColor #E6FCF5
  FontColor #063B2C
}
skinparam cloud {
  BorderColor #868E96
  BackgroundColor #F1F3F5
  FontColor #212529
}

rectangle "React UI /\nAPI Client" as client #F1F3F5
cloud "External\nFlow Auth" as flow_auth
database "Postgres\n----\nRecord database" as postgres
rectangle "File Store\n----\nEvidence and\nartifact objects" as file_store #E6FCF5

package "FastAPI Backend - Modular Monolith" as backend #F8FBFF {
  package "HTTP + Auth Boundary" as http_boundary #EDF2FF {
    rectangle "API Router\n----\nHTTP only\nrequest -> service\nerror -> response" as api_router
    rectangle "Current Actor\nDependency\n----\nBearer token ->\nActorContext" as current_actor
    rectangle "Permission\nPolicies\n----\nRole and object\nvisibility checks" as permissions
    rectangle "Pydantic\nSchemas\n----\nRequest/response\ncontracts" as schemas
  }

  package "Workflow Services" as workflow_services #E7F5FF {
    rectangle "Project Guide\nService\n----\nProjects, guides,\nchecker/review/revision\npolicies" as project_service
    rectangle "Task Queue\nService\n----\nTask contract,\nscreening, release,\nclaim, assignment,\nstate guards" as task_service
    rectangle "Submission\nService\n----\nPackets, evidence,\nartifact manifest,\nversions, locking" as submission_service
    rectangle "Checker\nService\n----\nChecker runs,\nblocking results,\npre-review gate" as checker_service
    rectangle "Review + Revision\nService\n----\naccept,\nneeds_revision,\nreject, findings,\nrevision replay" as review_service
    rectangle "Contribution /\nCompensation /\nReputation\nService\n----\nReviewer/submitter records,\naward fulfillment,\noutcome events" as ledger_service
  }

  package "Shared Domain Rules" as shared_rules #EDF2FF {
    rectangle "Lifecycle\nGuards\n----\nAllowed task and\nsubmission transitions" as lifecycle
    rectangle "Audit\nService\n----\nAppend-only\nworkflow events" as audit_service
  }

  package "Persistence Boundary" as persistence #E6FCF5 {
    rectangle "Repositories\n----\nProject, task,\nsubmission, checker,\nreview, ledger,\naudit persistence" as repositories #E6FCF5
  }

  package "External Ports + Adapters" as ports #FFF3BF {
    rectangle "Auth Verifier\nInterface" as auth_port #FFF3BF
    rectangle "Flow Auth\nAdapter" as flow_adapter #FFF3BF
    rectangle "Storage Port" as storage_port #FFF3BF
    rectangle "Local Storage\nAdapter" as storage_adapter #FFF3BF
    rectangle "Checker Runner\nAdapter" as checker_runner #FFF3BF
  }
}

client --> http_boundary : HTTP/JSON
http_boundary --> workflow_services : route to domain services
http_boundary --> ports : verify actor

workflow_services --> shared_rules : state, audit, policy rules
workflow_services --> persistence : read/write records
workflow_services --> ports : storage and checker execution

ports --> flow_auth : verify token
ports --> file_store : store/read artifacts
persistence --> postgres : SQLAlchemy async

@enduml
