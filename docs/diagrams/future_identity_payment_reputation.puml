@startuml future_identity_payment_reputation
title Future Identity, Task Contract, Settlement, And Reputation View

left to right direction

skinparam backgroundColor #FFFFFF
skinparam shadowing false
skinparam roundcorner 8
skinparam defaultFontName Arial
skinparam defaultFontSize 15
skinparam ArrowColor #495057
skinparam ArrowThickness 1.2
skinparam packageStyle rectangle
skinparam rectangle {
  BorderColor #1C7ED6
  BackgroundColor #E7F5FF
  FontColor #0B2942
}
skinparam cloud {
  BorderColor #868E96
  BackgroundColor #F1F3F5
  FontColor #212529
}

package "Contributor Unit" #F8F9FA {
  rectangle "Human\n----\nFlow identity\nsubject" as human #F1F3F5
  rectangle "Agent\n----\nERC-8004\nidentity" as agent #F1F3F5
  rectangle "Human-Agent\nContributor\n----\nOne accountable\nWorkstream actor" as contributor #F1F3F5
}

cloud "Flow Identity Layer\n----\nHuman identity,\nauth token,\nhuman-agent link" as flow_identity

package "Future Identity / Contract Rails" #FFF9DB {
  rectangle "ERC-8004\n----\nAgent identity\nand agent reputation\nregistry" as erc8004 #FFF3BF
  rectangle "ERC-8183\n----\nTask contract\nand escrow layer" as erc8183 #FFF3BF
}

package "Workstream" #F8FBFF {
  rectangle "Claim /\nSubmission Gate\n----\nPolicy, identity,\nagent id, reputation,\ncontract references" as gate
  rectangle "Evaluation\nLifecycle\n----\nguide -> task ->\nsubmission -> checks ->\nreview -> revision" as lifecycle
  rectangle "Contribution\nRecord\n----\nReviewer or submitter\nwork under locked\nevidence" as contribution #E6FCF5
  rectangle "Compensation\nAward\n----\nInstrument, unit,\nquantity, policy,\nbinding" as compensation_award #E6FCF5
  rectangle "Reputation\nEvent\n----\nHuman and\nagent-linked\noutcome signal" as reputation_record #E6FCF5
}

package "Future Settlement Rails" #FFF9DB {
  rectangle "Payment Link /\nRequest\n----\nGenerated from\npayable money award" as payment_link #FFF3BF
  rectangle "x402\n----\nPayment request\nprotocol" as x402 #FFF3BF
  rectangle "OmniClaw\n----\nSettlement\norchestration" as omniclaw #FFF3BF
  rectangle "USDC\nStablecoin\n----\nPayout asset" as usdc #FFF3BF
}

human --> contributor : accountable human
agent --> contributor : assists
human --> flow_identity : authenticates
flow_identity --> gate : trusted identity
agent --> erc8004 : has id
erc8004 ..> gate : read reputation
erc8183 ..> gate : task contract ref

gate --> lifecycle : allows work
lifecycle --> contribution : valid human review\n+ accept adds submitter
contribution --> compensation_award : only when payable
contribution --> reputation_record : outcome event

compensation_award ..> payment_link : create request
payment_link ..> x402
x402 ..> omniclaw
omniclaw ..> usdc : settle
usdc ..> compensation_award : fulfillment receipt
reputation_record ..> erc8004 : optional write

@enduml
